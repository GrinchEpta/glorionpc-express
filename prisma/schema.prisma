generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 Int            @id @default(autoincrement())
  name               String
  description        String
  price              Float
  oldPrice           Float?
  category           String

  cpu                String?
  gpu                String?
  ram                String?
  ssd                String?

  inStock            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  componentType      String?
  isConfiguratorItem Boolean        @default(false)

  socket             String?
  ramType            String?
  chipset            String?
  formFactor         String?

  memoryCapacity     String?
  storageType        String?
  storageCapacity    String?

  powerDraw          Int?
  recommendedPsu     Int?
  psuWattage         Int?

  coolingLevel       String?
  supportedSockets   String?

  gpuLength          Int?
  gpuWidth           Int?
  gpuHeight          Int?

  specsJson          String?

  avitoItemId        String?        @unique
  avitoUrl           String?
  avitoPrice         Float?
  avitoStatus        String?
  avitoLastSyncedAt  DateTime?
  syncSource         String?

  orderItems         OrderItem[]
  images             ProductImage[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id           Int         @id @default(autoincrement())
  customerName String
  phone        String
  email        String
  comment      String?
  total        Float
  status       OrderStatus @default(new)
  createdAt    DateTime    @default(now())
  customerId   Int?

  items        OrderItem[]
  customer     Customer?   @relation(fields: [customerId], references: [id])
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  productId    Int?
  productName  String?
  productImage String?
  specs        String?
  quantity     Int
  price        Int

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id])
}

model CustomPcRequest {
  id            Int         @id @default(autoincrement())
  customerName  String
  phone         String
  email         String
  budget        Int?
  designWishes  String?
  caseSize      String?
  purpose       String?
  comment       String?
  status        OrderStatus @default(new)
  createdAt     DateTime    @default(now())
  customerId    Int?

  customer      Customer?   @relation(fields: [customerId], references: [id])
}

model IntegrationToken {
  id           Int      @id @default(autoincrement())
  provider     String   @unique
  accessToken  String
  refreshToken String?
  tokenType    String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id               Int               @id @default(autoincrement())
  phone            String            @unique
  name             String?
  email            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  orders           Order[]
  customPcRequests CustomPcRequest[]
}

model PhoneLoginCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum OrderStatus {
  new
  processing
  completed
  cancelled
}
