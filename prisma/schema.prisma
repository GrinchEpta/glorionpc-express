generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int            @id @default(autoincrement())
  name        String
  description String
  price       Float
  oldPrice    Float?
  category    String
  cpu         String?
  gpu         String?
  ram         String?
  ssd         String?
  inStock     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orderItems  OrderItem[]
  images      ProductImage[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id           Int         @id @default(autoincrement())
  customerName String
  phone        String
  email        String
  comment      String?
  total        Float
  status       OrderStatus @default(new)
  createdAt    DateTime    @default(now())

  items OrderItem[]
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float

  orderId   Int
  productId Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  new
  processing
  completed
  cancelled
}
